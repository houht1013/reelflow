# Local-only vars for `wrangler dev`
# Copy this file to `.dev.vars` (do not commit `.dev.vars`).

# Use local Worker URL for local auth callbacks
APP_BASE_URL=http://localhost:8788
BETTER_AUTH_URL=http://localhost:8788

# Minimal required backend variables for local startup
DATABASE_URL=postgresql://username:password@localhost:5432/shipeasy_dev
BETTER_AUTH_SECRET=replace-with-a-random-32-char-min-secret

# Hyperdrive local connection is configured in `wrangler.jsonc` via
# `hyperdrive[].localConnectionString`, so no extra env var is needed here.

# Optional placeholders (fill only if you use these features)
# STRIPE_SECRET_KEY=
# OPENAI_API_KEY=
