{
  "name": "@tinyship/tanstack-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 7001",
    "dev:cf": "cross-env CF_DEPLOY=1 vite dev --port 7001",
    "preview:cf": "cross-env CF_DEPLOY=1 pnpm exec vite build && pnpm exec wrangler dev --port 7001",
    "build": "cross-env CF_DEPLOY=1 vite build",
    "start": "NODE_ENV=production node .output/server/index.mjs",
    "deploy:cf": "cross-env CF_DEPLOY=1 vite build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
