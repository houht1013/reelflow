    "@types/node": "^22",
    "@types/qrcode": "1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "cross-env": "^7.0.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vite-plugin-node-polyfills": "0.25.0",
    "vite-plugin-svgr": "4.5.0",
