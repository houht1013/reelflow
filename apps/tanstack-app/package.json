    "@tanstack/react-table": "8.21.2",
    "@uiw/react-md-editor": "4.0.11",
    "@xyflow/react": "12.11.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "^12.23.0",
    "input-otp": "1.4.2",
    "lucide-react": "0.484.0",
    "qrcode": "1.5.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-hook-form": "^7.55.0",
    "react-markdown": "10.1.0",
    "recharts": "2.15.3",
