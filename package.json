{
  "name": "tinyship",
  "version": "0.0.1",
  "private": true,
  "description": "Tinyship SaaS Template - A comprehensive monorepo for building subscription-based web applications",
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@9.4.0",
  "scripts": {
    "dev:next": "turbo run dev --filter=@tinyship/next-app",
    "dev:nuxt": "turbo run dev --filter=@tinyship/nuxt-app",
    "dev:tanstack": "turbo run dev --filter=@tinyship/tanstack-app",
    "dev:local": "powershell -ExecutionPolicy Bypass -File ./scripts/start-dev.ps1",
    "dev:worker": "corepack pnpm --filter @reelflow/execution-worker dev",
    "dev:docs": "turbo run dev --filter=docs-app",
    "build:next": "turbo run build --filter=@tinyship/next-app",
    "build:nuxt": "turbo run build --filter=@tinyship/nuxt-app",
    "build:tanstack": "turbo run build --filter=@tinyship/tanstack-app",
    "build:docs": "turbo run build --filter=docs-app",
    "start:next": "turbo run start --filter=@tinyship/next-app",
    "start:nuxt": "turbo run start --filter=@tinyship/nuxt-app",
    "start:tanstack": "turbo run start --filter=@tinyship/tanstack-app",
    "start:worker": "corepack pnpm --filter @reelflow/execution-worker start",
    "worker:start": "corepack pnpm --filter @reelflow/execution-worker start",
    "worker:once": "corepack pnpm --filter @reelflow/execution-worker once",
    "worker:health": "corepack pnpm --filter @reelflow/execution-worker health",
    "start:docs": "turbo run start --filter=docs-app",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:check": "node libs/database/scripts.js check",
    "db:push": "node libs/database/scripts.js push",
    "db:generate": "node libs/database/scripts.js generate",
    "db:migrate": "node libs/database/scripts.js migrate",
    "db:seed": "node libs/database/scripts.js seed",
    "db:studio": "node libs/database/scripts.js studio",
    "db:check:sqlite": "node libs/database/scripts.js check:sqlite",
    "db:generate:sqlite": "node libs/database/scripts.js generate:sqlite",
    "db:push:sqlite": "node libs/database/scripts.js push:sqlite",
    "db:migrate:sqlite": "node libs/database/scripts.js migrate:sqlite",
    "db:seed:sqlite": "node libs/database/scripts.js seed:sqlite",
    "db:studio:sqlite": "node libs/database/scripts.js studio:sqlite",
    "test": "vitest run",
    "test:api": "vitest run --config vitest.api.config.ts",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "npx playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config=tests/e2e/playwright.config.ts --ui",
    "smoke:reelflow:worker": "tsx tests/smoke/reelflow-worker-smoke.ts",
    "reelflow:sync-templates": "tsx scripts/sync-reelflow-templates.ts",
    "typecheck": "turbo run typecheck",
    "typecheck:next": "turbo run typecheck --filter=@tinyship/next-app",
    "typecheck:nuxt": "turbo run typecheck --filter=@tinyship/nuxt-app",
    "typecheck:tanstack": "turbo run typecheck --filter=@tinyship/tanstack-app",
    "typecheck:worker": "corepack pnpm --filter @reelflow/execution-worker typecheck",
    "email:compile": "tsx libs/email/templates/compile.ts",
    "email:test": "tsx libs/email/scripts.ts"
  },
  "keywords": [
    "saas",
    "subscription",
    "next.js",
    "nuxt.js",
    "monorepo"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/ali-oss": "^6.16.11",
    "@types/better-sqlite3": "7.6.13",
    "@types/mjml": "4.7.4",
    "@types/node": "^22.16.0",
    "@types/pg": "8.15.4",
    "@vitest/ui": "3.0.9",
    "better-sqlite3": "12.9.0",
    "drizzle-kit": "0.30.5",
    "mjml": "4.15.3",
    "turbo": "^1.11.2",
    "typescript": "^5.8.3",
    "vitest": "3.0.9"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "1.0.23",
    "@ai-sdk/fal": "2.0.20",
    "@ai-sdk/google": "3.0.33",
    "@ai-sdk/openai": "3.0.2",
    "@ai-sdk/openai-compatible": "1.0.22",
    "@alicloud/dysmsapi20170525": "3.1.1",
    "@alicloud/openapi-client": "0.4.13",
    "@alicloud/tea-util": "1.4.10",
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@casl/ability": "6.7.3",
    "@formatjs/intl-localematcher": "0.6.1",
    "@peculiar/x509": "1.12.3",
    "@types/chalk": "2.2.4",
    "@types/negotiator": "0.6.3",
    "ai": "6.0.82",
    "ali-oss": "^6.21.0",
    "alipay-sdk": "4.14.0",
    "better-auth": "1.4.10",
    "chalk": "5.4.1",
    "cos-nodejs-sdk-v5": "^2.15.3",
    "creem": "0.4.0",
    "dodopayments": "2.32.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.40.1",
    "fflate": "0.8.3",
    "formidable": "1.2.6",
    "handlebars": "4.7.8",
    "nanoid": "5.1.5",
    "negotiator": "1.0.0",
    "ofetch": "1.4.1",
    "pg": "^8.14.1",
    "resend": "4.1.2",
    "stripe": "18.1.0",
    "tsx": "^4.19.3",
    "twilio": "5.5.2",
    "validation-better-auth": "1.1.1",
    "zod": "4.2.1"
  }
}
