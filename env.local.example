# Reelflow local development defaults for Windows.
# Copy to .env.local. Values here are intentionally local-only.

APP_BASE_URL=http://localhost:7001
VITE_APP_URL=http://localhost:7001

DB_DIALECT=pg
DATABASE_URL=postgresql://reelflow:reelflow@localhost:55432/reelflow

BETTER_AUTH_URL=http://localhost:7001
BETTER_AUTH_SECRET=reelflow-local-development-secret-please-change

# Keep cloud rendering mocked in local development until a real render API is configured.
REELFLOW_CLOUD_RENDER_PROVIDER=cloud-render
REELFLOW_CLOUD_RENDER_MODEL=mp4-1080p
REELFLOW_CLOUD_RENDER_ENDPOINT=
REELFLOW_CLOUD_RENDER_API_KEY=
REELFLOW_CLOUD_RENDER_MOCK=1
